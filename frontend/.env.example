# Vite — only VITE_* variables are exposed to the client bundle.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# LiveKit (optional — backend health check can auto-select transport)
VITE_USE_LIVEKIT=
VITE_LIVEKIT_URL=

# Sentry (optional)
VITE_SENTRY_DSN=

# Email verification gate (set false for local dev to skip /verify-email)
VITE_REQUIRE_EMAIL_VERIFICATION=true
