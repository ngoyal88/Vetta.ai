# Backend configuration
JWT_SECRET_KEY=change-me-to-a-random-hex-64
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
ALLOWED_ORIGIN_REGEX=
API_TOKEN=

# LLM
LLM_PROVIDER=groq
LLM_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: override model for JSON adjudication (defaults to GROQ_MODEL). Avoid tiny instant models for JD Fit.
# GROQ_JSON_MODEL=llama-3.3-70b-versatile
LLM_MODEL=gemini-2.5-flash

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Keep false in dev: run agent separately with `python run_livekit_agent.py dev`
LIVEKIT_AGENT_EMBEDDED=false

# WebSocket interview fallback (when LiveKit unavailable). Requires DEEPGRAM_API_KEY.
INTERVIEW_WEBSOCKET_FALLBACK_ENABLED=true

# Speech / TTS
DEEPGRAM_API_KEY=
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz
ELEVENLABS_API_KEY=
TTS_PROVIDER=edge

# Code execution
JUDGE0_API_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase
FIREBASE_PROJECT_ID=mock-interview-5259f
FIREBASE_CREDENTIALS_PATH=serviceAccount.json

# Contact form (pick one free notification channel; Firestore storage always runs when Firebase creds exist)
CONTACT_RECIPIENT_EMAIL=hello@vetta.ai

CONTACT_RATE_LIMIT=5
CONTACT_RATE_WINDOW_SECONDS=3600

# Supabase Storage (vault resume files). If unset, files are stored under VAULT_STORAGE_DIR locally.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VAULT_BUCKET=Resume
VAULT_STORAGE_DIR=data/vault

# Interview settings
MAX_INTERVIEW_DURATION_MINUTES=60
MAX_QUESTIONS_PER_INTERVIEW=15
DSA_TIME_LIMIT_MINUTES=45

# Feature flags
JD_FIT_ENABLED=true
JD_FIT_SEMANTIC_ALIGNMENT_ENABLED=true
VPM_ENABLED=true
RESUME_BUILDER_ENABLED=false

# Resume Builder compile service
COMPILE_SERVICE_URL=http://127.0.0.1:8001
COMPILE_SERVICE_TOKEN=change-me-local-dev
TECTONIC_BIN=tectonic
VITE_RESUME_BUILDER_ENABLED=false

EXPOSE_API_ERRORS=false
REQUIRE_EMAIL_VERIFIED=true
RATE_LIMIT_FAIL_OPEN=false
# Enable only when behind a load balancer / reverse proxy
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=127.0.0.1
